Settings {
  min-width: 60;
  width: auto;
  height: auto;
  scrollbar-size-vertical: 0;
}


Stat {
  width: 40;
  height: 3;
}

Rule {
  margin: 0;
}

Switch {
  padding: 0;
  border: none;
  background: $background;
}

.statistic-row {
  width: 40;
}

.statistic-data {
  dock: right;
}


.setting-row {
  width: 60;
  padding: 0 1;
  &:focus-within {
    tint: $secondary;
  }
}

.height-auto {
  height: auto;
}

.width-auto {
  width: auto;
}

.hidden {
  display: none;
}

.setting-label {
  padding: 0 0 0 1;
  width: 100%;
}

.setting-select {
  padding: 0 1 0 0;
  dock: right;
  width: 30;
}

.setting-input {
  padding: 0 1 0 0;
  dock: right;
  width: 10;
}

.setting-switch {
  padding: 0 1 0 0;
  dock: right;
  width: 6;
}

